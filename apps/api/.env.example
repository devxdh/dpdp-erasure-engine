# Compliance Control Plane API
# Copy to api/.env for local development, or inject these through Docker/Kubernetes secrets.

NODE_ENV=development
ALLOW_LOCAL_DEV=true
PORT=3000
LOG_LEVEL=info

# Mandatory Legal Acknowledgement: Sets liability shift and confirms Apache 2.0 terms
I_ACCEPT_APACHE2_AND_DPDP_OPERATIONAL_LIABILITY=true

# Postgres database used by the Control Plane.
DATABASE_URL=postgres://dpdp:dpdp@127.0.0.1:55432/dpdp_local
API_CONTROL_SCHEMA=dpdp_control

# Worker authentication. WORKER_SHARED_SECRET must match the worker API_WORKER_TOKEN.
WORKER_CLIENT_NAME=worker-1
WORKER_SHARED_SECRET=replace-with-worker-token
WORKER_REQUEST_SIGNING_SECRET=replace-with-worker-request-signing-secret
WORKER_REQUEST_SIGNING_MAX_SKEW_MS=60000

# Admin/BFF token used by the web dashboard. Keep server-side only.
ADMIN_API_TOKEN=replace-with-admin-api-token

# Task leasing, retries, and lifecycle scheduler.
WORKER_TASK_LEASE_SECONDS=60
TASK_MAX_ATTEMPTS=10
TASK_BASE_BACKOFF_MS=1000
LIFECYCLE_MATERIALIZER_INTERVAL_MS=5000
LIFECYCLE_MATERIALIZER_BATCH_SIZE=1000

# Public ingestion and webhook safety.
PUBLIC_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_RATE_LIMIT_MAX_REQUESTS=60
MAX_OUTBOX_PAYLOAD_BYTES=32768
WEBHOOK_TIMEOUT_MS=10000

# Shadow-mode burn-in gate.
SHADOW_BURN_IN_REQUIRED=true
SHADOW_REQUIRED_SUCCESSES=100

# Certificate of Erasure signing keys.
# Generate real Ed25519 keys before production. Production fails closed if these are missing.
COE_KEY_ID=control-plane-ed25519-v1
COE_PRIVATE_KEY_PKCS8_BASE64=replace-with-ed25519-private-key-pkcs8-base64
COE_PUBLIC_KEY_SPKI_BASE64=replace-with-ed25519-public-key-spki-base64

# Optional immutable archive export.
ARCHIVE_S3_ENABLED=false
ARCHIVE_S3_BUCKET=
ARCHIVE_S3_REGION=
ARCHIVE_S3_ENDPOINT=
ARCHIVE_S3_ACCESS_KEY_ID=
ARCHIVE_S3_SECRET_ACCESS_KEY=
ARCHIVE_INTERVAL_MS=3600000

# Test runner override.
TEST_DATABASE_URL=postgres://dpdp:dpdp@127.0.0.1:55432/dpdp_local
