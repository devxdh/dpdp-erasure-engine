# Avantii local orchestration and benchmark scripts

# Shared local Postgres URL used by local-e2e and mega-e2e scripts.
LOCAL_DATABASE_URL=postgres://dpdp:dpdp@127.0.0.1:55432/dpdp_local
LOCAL_APP_SCHEMA=public
LOCAL_ENGINE_SCHEMA=dpdp_engine

# Local service endpoints exposed by docker-compose.yml.
DPDP_LOCAL_API_URL=http://127.0.0.1:13000
DPDP_LOCAL_GATEWAY_URL=http://127.0.0.1:18080

# Keep local docker-compose services alive after E2E for manual inspection.
DPDP_E2E_KEEP_UP=0

# Mega E2E sizing. Increase gradually; 100k jobs requires enough disk, CPU, and time.
DPDP_MEGA_TOTAL_USERS=1000
DPDP_MEGA_PURGE_REQUESTS=5
DPDP_MEGA_DELETE_REQUESTS=2
DPDP_MEGA_WORKERS=3
DPDP_MEGA_REQUEST_CONCURRENCY=4
DPDP_MEGA_JOB_TIMEOUT_MS=180000
DPDP_MEGA_TENANT_API_TOKEN=
